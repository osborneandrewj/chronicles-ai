# Chronicles AI — environment variables (server / @chronicles/server)
#
# Copy this file to `.env.local` IN THIS DIRECTORY (packages/server/.env.local)
# and fill in the secrets. Next.js loads .env files from the package it runs in
# (`next dev` runs with cwd = packages/server), NOT from the monorepo root — a
# root-level .env.local is ignored.
#
# Only the two API keys are required to take a turn locally. Everything else has
# a working default and can be omitted.

# ── Required: LLM provider keys ──────────────────────────────────────────────
# Grok narrator/seeder/actor + xAI TTS. Without it, taking a turn fails with
# "XAI_API_KEY is not set". Get one at https://console.x.ai → API keys.
XAI_API_KEY=xai-...

# Haiku agents (archivist, classifier, intent reconciler, region extractor,
# npc-agent, world generator). Read automatically by @ai-sdk/anthropic.
ANTHROPIC_API_KEY=sk-ant-...

# ── Persistence selection ────────────────────────────────────────────────────
# Which store the app runs on. Default (unset) = sqlite, using your local
# chronicles.sqlite at the repo root. Set to `mongo` ONLY when you want to run
# against MongoDB — requires DATABASE_URL below and a seeded Mongo database.
# Tip: leave this UNSET in .env.local so plain `npm run dev` stays on SQLite,
# and pass `PERSISTENCE=mongo DATABASE_URL=... npm run dev` inline when testing Mongo.
# PERSISTENCE=mongo

# MongoDB connection string. Required only when PERSISTENCE=mongo. Must point at
# a replica set (single-node is fine) — the adapter refuses a standalone mongod
# because transactions require one. Local Docker single-node replica set:
# DATABASE_URL=mongodb://localhost:27017/chronicles?replicaSet=rs0

# Override the SQLite file path (SQLite path only). Unset → repo-root
# chronicles.sqlite for local dev; set to the mounted volume path in prod.
# DATABASE_PATH=

# ── Optional: cost cap ───────────────────────────────────────────────────────
# Per-day token ceiling across all LLM calls. Has a built-in default if unset.
# DAILY_TOKEN_LIMIT=200000

# ── Optional: TTS (xAI) ──────────────────────────────────────────────────────
# Narration voice_id sent to xAI TTS. Defaults to `eve`.
# TTS_VOICE=eve
# Speech rate multiplier, 0.7–1.5 (default 1.0). Out-of-range values are ignored.
# TTS_SPEED=1.0

# ── Optional: map / route grounding ──────────────────────────────────────────
# Route provider. Defaults to `osm`.
# MAP_ROUTE_PROVIDER=osm
# User-Agent sent to map/geocoding APIs (set a contact per OSM usage policy).
# MAP_TOOL_USER_AGENT=chronicles-ai/0.1.0 route-grounding (you@example.com)
