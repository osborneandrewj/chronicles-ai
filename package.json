{
  "name": "chronicles-ai",
  "version": "0.6.21",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm -w @chronicles/server run dev",
    "build": "npm -w @chronicles/server run build",
    "start": "npm -w @chronicles/server run start",
    "lint": "npm -w @chronicles/server run lint",
    "type-check": "npm -w @chronicles/server run type-check",
    "test": "npm -w @chronicles/server run test",
    "test:watch": "npm -w @chronicles/server run test:watch"
  }
}
